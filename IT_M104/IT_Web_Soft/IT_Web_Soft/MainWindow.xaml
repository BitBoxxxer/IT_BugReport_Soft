<Window x:Class="LogViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LogViewer"
        xmlns:models="clr-namespace:LogViewer.Models"
        mc:Ignorable="d"
        Title="Log Viewer - IT Top College Journal" 
        Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#0F0F0F"
        Foreground="#E0E0E0">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#404040"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"
                                            Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A3A3A"/>
                                <Setter Property="BorderBrush" Value="#505050"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1A1A1A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#404040"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#2196F3"/>
            <Setter Property="SelectionBrush" Value="#2196F3"/>
            <Setter Property="SelectionTextBrush" Value="White"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="12,0,0,0"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#404040"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="Separator">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Margin" Value="12,0"/>
        </Style>

        <Style TargetType="ListView">
            <Setter Property="Background" Value="#0F0F0F"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#2A2A2A"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#2A2A2A"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="ScrollViewer">
            <Setter Property="Background" Value="#0F0F0F"/>
        </Style>

        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A2A2A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1A1A1A" Padding="16,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Log Viewer" 
                         FontSize="18" FontWeight="Medium" 
                         VerticalAlignment="Center"/>
                <TextBlock Text="IT Top College Journal" 
                         FontSize="13" 
                         Foreground="#AAAAAA"
                         Margin="12,0,0,0"
                         VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Control Panel -->
        <Border Grid.Row="1" Background="#1A1A1A" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left Buttons -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button x:Name="BtnOpenFile" Content="Open File" 
                            Click="BtnOpenFile_Click" ToolTip="Open encrypted log file"/>
                    <Button x:Name="BtnRefresh" Content="Refresh" 
                            Click="BtnRefresh_Click" ToolTip="Refresh log list"/>
                    <Button x:Name="BtnExport" Content="Export" 
                            Click="BtnExport_Click" ToolTip="Export to TXT"/>
                    <Button x:Name="BtnStatistics" Content="Statistics" 
                            Click="BtnStatistics_Click" ToolTip="View statistics and reports"/>
                </StackPanel>

                <!-- Center Filters -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Search" Margin="0,0,8,0"/>
                    <TextBox x:Name="TxtSearch" Width="200" 
                             TextChanged="TxtSearch_TextChanged"
                             ToolTip="Search in logs"/>
                    
                    <Separator/>
                    
                    <TextBlock Text="Category" Margin="8,0,8,0"/>
                    <ComboBox x:Name="CbCategoryFilter" Width="120" 
                             SelectionChanged="CbCategoryFilter_SelectionChanged">
                        <ComboBoxItem Content="All" IsSelected="True"/>
                        <ComboBoxItem Content="System"/>
                        <ComboBoxItem Content="User"/>
                        <ComboBoxItem Content="Network"/>
                        <ComboBoxItem Content="Database"/>
                        <ComboBoxItem Content="Security"/>
                        <ComboBoxItem Content="Application"/>
                        <ComboBoxItem Content="Performance"/>
                        <ComboBoxItem Content="Other"/>
                    </ComboBox>
                    
                    <Separator/>
                    
                    <TextBlock Text="Status" Margin="8,0,8,0"/>
                    <ComboBox x:Name="CbStatusFilter" Width="120" 
                             SelectionChanged="CbStatusFilter_SelectionChanged">
                        <ComboBoxItem Content="All" IsSelected="True"/>
                        <ComboBoxItem Content="New"/>
                        <ComboBoxItem Content="In Progress"/>
                        <ComboBoxItem Content="Resolved"/>
                        <ComboBoxItem Content="Ignored"/>
                        <ComboBoxItem Content="Critical"/>
                        <ComboBoxItem Content="Archived"/>
                    </ComboBox>
                </StackPanel>

                <!-- Right Buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="BtnAddEntry" Content="Add" 
                            Click="BtnAddEntry_Click" Background="#2196F3" ToolTip="Add new entry"/>
                    <Button x:Name="BtnEditEntry" Content="Edit" 
                            Click="BtnEditEntry_Click" ToolTip="Edit selected entry"/>
                    <Button x:Name="BtnDeleteEntry" Content="Delete" 
                            Click="BtnDeleteEntry_Click" Background="#C62828" ToolTip="Delete selected entry"/>
                    <Button x:Name="BtnClearFilter" Content="Clear Filters" 
                            Click="BtnClearFilter_Click" ToolTip="Clear all filters"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Log List -->
        <Grid Grid.Row="2" Margin="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- Entry List -->
            <ListView x:Name="LvLogEntries" Grid.Column="0" 
                      SelectionChanged="LvLogEntries_SelectionChanged"
                      BorderThickness="0,0,1,0" 
                      BorderBrush="#2A2A2A">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Time" Width="70">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Padding="8" Background="Transparent">
                                        <TextBlock Text="{Binding Timestamp, StringFormat='HH:mm:ss'}" 
                                                   FontFamily="Consolas"
                                                   FontSize="12"/>
                                    </Border>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Type" Width="80">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Padding="8" Background="Transparent">
                                        <TextBlock Text="{Binding ActionType}" 
                                                   FontFamily="Consolas"
                                                   FontSize="12">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#E0E0E0"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsError}" Value="True">
                                                            <Setter Property="Foreground" Value="#FF6B6B"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Status" Width="70">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Padding="8" Background="Transparent">
                                        <TextBlock Text="{Binding StatusDisplayName}" FontSize="11">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="{x:Static models:LogStatus.Critical}">
                                                            <Setter Property="Foreground" Value="#F44336"/>
                                                            <Setter Property="FontWeight" Value="Bold"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="{x:Static models:LogStatus.Resolved}">
                                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="{x:Static models:LogStatus.New}">
                                                            <Setter Property="Foreground" Value="#2196F3"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Description" Width="100">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Padding="8" Background="Transparent">
                                        <TextBlock Text="{Binding Description}" 
                                                   TextTrimming="CharacterEllipsis"
                                                   FontSize="12"/>
                                    </Border>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>

                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <Border x:Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#2A2A2A"/>
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#404040"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#252525"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>

            <!-- Detail Panel -->
            <Border Grid.Column="1" Background="#0F0F0F">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#1A1A1A" Padding="12">
                        <TextBlock x:Name="TxtDetailHeader" 
                                 FontWeight="SemiBold" 
                                 FontSize="13"/>
                    </Border>

                    <ScrollViewer Grid.Row="1">
                        <TextBox x:Name="TxtDetailContent" 
                                 Background="#0F0F0F"
                                 Foreground="#E0E0E0"
                                 IsReadOnly="True" 
                                 BorderThickness="0"
                                 TextWrapping="Wrap"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 VerticalScrollBarVisibility="Auto"
                                 Padding="12"/>
                    </ScrollViewer>

                    <!-- Quick Actions -->
                    <Border Grid.Row="2" Background="#1A1A1A" Padding="12">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Change Status:" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <Button x:Name="BtnSetNew" Content="New" Click="BtnSetStatus_Click" Tag="{x:Static models:LogStatus.New}" Padding="8,4"/>
                            <Button x:Name="BtnSetInProgress" Content="In Progress" Click="BtnSetStatus_Click" Tag="{x:Static models:LogStatus.InProgress}" Padding="8,4"/>
                            <Button x:Name="BtnSetResolved" Content="Resolved" Click="BtnSetStatus_Click" Tag="{x:Static models:LogStatus.Resolved}" Padding="8,4"/>
                            <Button x:Name="BtnSetCritical" Content="Critical" Click="BtnSetStatus_Click" Tag="{x:Static models:LogStatus.Critical}" Padding="8,4" Background="#C62828"/>
                            <Button x:Name="BtnSetIgnored" Content="Ignored" Click="BtnSetStatus_Click" Tag="{x:Static models:LogStatus.Ignored}" Padding="8,4"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="#1A1A1A" BorderThickness="1,0,0,0" BorderBrush="#2A2A2A">
            <StatusBar Background="Transparent" Foreground="#AAAAAA">
                <StatusBarItem>
                    <TextBlock x:Name="TxtStatus" Text="Ready" FontSize="12"/>
                </StatusBarItem>
                <Separator/>
                <StatusBarItem>
                    <TextBlock x:Name="TxtFileInfo" Text="No file selected" FontSize="12"/>
                </StatusBarItem>
                <Separator/>
                <StatusBarItem>
                    <TextBlock x:Name="TxtFileType" Text="Type: -" FontSize="12"/>
                </StatusBarItem>
                <Separator/>
                <StatusBarItem>
                    <TextBlock x:Name="TxtEntryCount" Text="Entries: 0" FontSize="12"/>
                </StatusBarItem>
                <Separator/>
                <StatusBarItem>
                    <TextBlock x:Name="TxtErrorCount" Text="Errors: 0" FontSize="12" Foreground="#FF6B6B"/>
                </StatusBarItem>
            </StatusBar>
        </Border>
    </Grid>
</Window>