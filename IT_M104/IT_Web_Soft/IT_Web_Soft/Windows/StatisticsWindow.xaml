<Window x:Class="LogViewer.Windows.StatisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LogViewer.Windows"
        xmlns:models="clr-namespace:LogViewer.Models"
        mc:Ignorable="d"
        Title="Статистика и отчёты" 
        Height="600" Width="700"
        WindowStartupLocation="CenterOwner"
        Background="#0F0F0F"
        Foreground="#E0E0E0"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#404040"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Margin" Value="8,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"
                                            Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="StatValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#2196F3"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="StatLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="8"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Статистика и отчёты" 
                   FontSize="20" FontWeight="Medium"
                   Margin="0,0,0,20"/>

        <!-- Statistics Content -->
        <ScrollViewer Grid.Row="1">
            <StackPanel>
                <!-- Main Statistics Cards -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Total Entries -->
                    <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock x:Name="TxtTotalEntries" Text="0" 
                                      Style="{StaticResource StatValueStyle}"/>
                            <TextBlock Text="Всего записей" Style="{StaticResource StatLabelStyle}"/>
                        </StackPanel>
                    </Border>

                    <!-- Errors -->
                    <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock x:Name="TxtErrorCount" Text="0" 
                                      Style="{StaticResource StatValueStyle}" Foreground="#FF6B6B"/>
                            <TextBlock Text="Ошибок" Style="{StaticResource StatLabelStyle}"/>
                        </StackPanel>
                    </Border>

                    <!-- Critical -->
                    <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock x:Name="TxtCriticalCount" Text="0" 
                                      Style="{StaticResource StatValueStyle}" Foreground="#F44336"/>
                            <TextBlock Text="Критических" Style="{StaticResource StatLabelStyle}"/>
                        </StackPanel>
                    </Border>

                    <!-- Resolved -->
                    <Border Grid.Column="3" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock x:Name="TxtResolvedCount" Text="0" 
                                      Style="{StaticResource StatValueStyle}" Foreground="#4CAF50"/>
                            <TextBlock Text="Решённых" Style="{StaticResource StatLabelStyle}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Date Range -->
                <Border Style="{StaticResource CardStyle}" Margin="8,16,8,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Самая старая запись" Style="{StaticResource StatLabelStyle}"/>
                            <TextBlock x:Name="TxtOldestEntry" Text="-" FontSize="14" Margin="0,4,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Самая новая запись" Style="{StaticResource StatLabelStyle}"/>
                            <TextBlock x:Name="TxtNewestEntry" Text="-" FontSize="14" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- By Category -->
                <TextBlock Text="По категориям" FontSize="16" FontWeight="Medium" Margin="8,16,8,8"/>
                <Border Style="{StaticResource CardStyle}">
                    <ListView x:Name="LvByCategory" Background="Transparent" BorderThickness="0">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Category}" FontSize="13"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Count}" 
                                              Foreground="#2196F3" FontWeight="Bold" FontSize="13"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>

                <!-- By Status -->
                <TextBlock Text="По статусам" FontSize="16" FontWeight="Medium" Margin="8,16,8,8"/>
                <Border Style="{StaticResource CardStyle}">
                    <ListView x:Name="LvByStatus" Background="Transparent" BorderThickness="0">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <Border Width="12" Height="12" CornerRadius="2" Margin="0,0,8,0">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding Color}"/>
                                            </Border.Background>
                                        </Border>
                                        <TextBlock Text="{Binding Status}" FontSize="13"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding Count}" 
                                              Foreground="#2196F3" FontWeight="Bold" FontSize="13"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>

                <!-- Report Preview -->
                <TextBlock Text="Предпросмотр отчёта" FontSize="16" FontWeight="Medium" Margin="8,16,8,8"/>
                <Border Style="{StaticResource CardStyle}" Height="150">
                    <TextBox x:Name="TxtReportPreview" 
                            Background="#0F0F0F" Foreground="#E0E0E0"
                            IsReadOnly="True" BorderThickness="0"
                            TextWrapping="Wrap" FontFamily="Consolas" FontSize="11"
                            VerticalScrollBarVisibility="Auto"/>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="BtnExportReport" Content="Экспорт отчёта" Click="BtnExportReport_Click" Background="#2196F3">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1976D2"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button x:Name="BtnClose" Content="Закрыть" Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>