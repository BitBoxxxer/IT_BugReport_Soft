<Window x:Class="LogViewer.Windows.LogEntryEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LogViewer.Windows"
        xmlns:models="clr-namespace:LogViewer.Models"
        mc:Ignorable="d"
        Title="Редактор записи лога" 
        Height="550" Width="600"
        WindowStartupLocation="CenterOwner"
        Background="#0F0F0F"
        Foreground="#E0E0E0"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#404040"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Margin" Value="8,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"
                                            Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A3A3A"/>
                                <Setter Property="BorderBrush" Value="#505050"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1A1A1A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#404040"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#2196F3"/>
            <Setter Property="SelectionBrush" Value="#2196F3"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#404040"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="ErrorTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF6B6B"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="Visibility" Value="Collapsed"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" x:Name="TxtHeader" 
                   Text="Новая запись лога" 
                   FontSize="20" FontWeight="Medium"
                   Margin="0,0,0,20"/>

        <!-- Form -->
        <ScrollViewer Grid.Row="1">
            <StackPanel>
                <!-- Timestamp -->
                <TextBlock Text="Дата и время" Style="{StaticResource HeaderTextStyle}"/>
                <DatePicker x:Name="DpDate" Margin="0,0,0,16" 
                           SelectedDate="{Binding Timestamp}"/>
                
                <TextBlock Text="Время" Style="{StaticResource HeaderTextStyle}"/>
                <TextBox x:Name="TxtTime" Margin="0,0,0,16" 
                        Text="12:00:00" Width="100" HorizontalAlignment="Left"/>
                <TextBlock x:Name="TxtTimeError" Text="Неверный формат времени (ЧЧ:ММ:СС)" 
                          Style="{StaticResource ErrorTextStyle}"/>

                <!-- Action Type -->
                <TextBlock Text="Тип действия *" Style="{StaticResource HeaderTextStyle}"/>
                <TextBox x:Name="TxtActionType" Margin="0,0,0,16"
                        Text="{Binding ActionType, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock x:Name="TxtActionTypeError" Text="Тип действия обязателен" 
                          Style="{StaticResource ErrorTextStyle}"/>

                <!-- Description -->
                <TextBlock Text="Описание *" Style="{StaticResource HeaderTextStyle}"/>
                <TextBox x:Name="TxtDescription" Margin="0,0,0,16"
                        Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="Wrap" AcceptsReturn="True" Height="60"
                        VerticalScrollBarVisibility="Auto"/>
                <TextBlock x:Name="TxtDescriptionError" Text="Описание обязательно" 
                          Style="{StaticResource ErrorTextStyle}"/>

                <!-- Category -->
                <TextBlock Text="Категория" Style="{StaticResource HeaderTextStyle}"/>
                <ComboBox x:Name="CbCategory" Margin="0,0,0,16"
                         SelectedItem="{Binding Category}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Status -->
                <TextBlock Text="Статус" Style="{StaticResource HeaderTextStyle}"/>
                <ComboBox x:Name="CbStatus" Margin="0,0,0,16"
                         SelectedItem="{Binding Status}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- User Notes -->
                <TextBlock Text="Заметки пользователя" Style="{StaticResource HeaderTextStyle}"/>
                <TextBox x:Name="TxtUserNotes" Margin="0,0,0,16"
                        Text="{Binding UserNotes, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="Wrap" AcceptsReturn="True" Height="80"
                        VerticalScrollBarVisibility="Auto"/>

                <!-- Extra Info (JSON) -->
                <TextBlock Text="Доп. информация (JSON)" Style="{StaticResource HeaderTextStyle}"/>
                <TextBox x:Name="TxtExtraInfo" Margin="0,0,0,16"
                        TextWrapping="Wrap" AcceptsReturn="True" Height="60"
                        VerticalScrollBarVisibility="Auto"
                        FontFamily="Consolas" FontSize="12"/>
                <TextBlock x:Name="TxtExtraInfoError" Text="Неверный JSON" 
                          Style="{StaticResource ErrorTextStyle}"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="BtnSave" Content="Сохранить" Click="BtnSave_Click" Background="#2196F3">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1976D2"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button x:Name="BtnCancel" Content="Отмена" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>